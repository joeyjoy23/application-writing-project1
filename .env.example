# 也可在网页侧边栏选择提供商并手动输入 Key（优先于 .env）

# ── 云端历史（Neon PostgreSQL，可选）──
# 配置后 Streamlit Cloud 历史可持久保存；本地留空则仍用 history.db
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# 历史时间展示时区（库内为 UTC）；默认 Asia/Shanghai
# APP_TIMEZONE=Asia/Shanghai
# 分享链接前缀（Streamlit Cloud 应用完整 URL，无末尾斜杠）
# APP_BASE_URL=https://your-app.streamlit.app

# 管理员密码：侧边栏解锁后可查看全部用户历史（勿提交到 Git）
# ADMIN_PASSWORD=请改为长随机密码

# 默认提供商：deepseek / openai / gemini / dashscope / mimo / agnes / groq
LLM_PROVIDER=deepseek
# DeepSeek 官方：deepseek-v4-pro / deepseek-v4-flash（chat/reasoner 将于 2026-07-24 弃用，会自动映射）
# 智谱官方：glm-5.2 / glm-5.1 / glm-4.7
# MiMo 须用小写：mimo-v2.5-pro（勿写 MiMo-V2.5-Pro）
# Agnes：agnes-2.0-flash 或 agnes-2.0-flash-thinking（Brainstorming / Thinking）
# Groq：llama-3.3-70b-versatile / llama-4-scout-17b-16e-instruct
LLM_MODEL=

DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DASHSCOPE_API_KEY=

# 智谱 AI 官方 https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=

# 小米 MiMo（OpenAI 兼容）https://token-plan-cn.xiaomimimo.com/v1
MIMO_API_KEY=
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# Agnes AI（OpenAI 兼容）https://apihub.agnes-ai.com/v1 — Key 见 platform.agnes-ai.com
AGNES_API_KEY=
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# Groq（OpenAI 兼容）https://api.groq.com/openai/v1 — Key 见 console.groq.com
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENAI_TEMPERATURE=0.7
# 未在 workflow 中单独指定阶段上限时的兜底（各 Stage 默认见 workflow.py）
OPENAI_MAX_TOKENS=8192

# 各 Stage 输出 token 上限（completion only；仅设天花板，模型仍受 Prompt 约束篇幅）
# STAGE1_MAX_TOKENS=8192
# STAGE2_MAX_TOKENS=8192
# STAGE3_MAX_TOKENS=6144
# STAGE4_MAX_TOKENS=6144

# 单 Stage 应用层超时（秒）：后台线程 join 上限，默认 300；慢模型可增至 420–600
STAGE_TIMEOUT_SECONDS=300
# API 超时（秒）：连接 / 读取
API_CONNECT_TIMEOUT_SECONDS=30
API_READ_TIMEOUT_SECONDS=300
# 流式：首字超时（秒），防止一直停在 Calling API
STREAM_FIRST_CHUNK_TIMEOUT_SECONDS=120
# 流式：两次输出之间无新内容的超时（秒）
STREAM_IDLE_TIMEOUT_SECONDS=180
# 流式：每收到多少字刷新一次界面（越小越灵敏，略增卡顿）
STREAM_UI_UPDATE_CHARS=40

# 历史题目原图保留天数（过期后仅保留识别文字，默认 7）
# HISTORY_IMAGE_RETENTION_DAYS=7

# ── API 重试 ──
# 最大重试次数（不含首次尝试）；0 = 不重试；超时/限流/连接失败自动重试，401/400/404 不重试
LLM_MAX_RETRIES=3
# 重试基础延迟（秒），实际延迟 = base × 2^attempt（如 base=2 → 2s, 4s, 8s）
LLM_RETRY_BASE_DELAY=2
