# 也可在网页侧边栏选择提供商并手动输入 Key（优先于 .env）

# ── 云端历史（Neon PostgreSQL，可选）──
# 配置后 Streamlit Cloud 历史可持久保存；本地留空则仍用 history.db
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# 管理员密码：侧边栏解锁后可查看全部用户历史（勿提交到 Git）
# ADMIN_PASSWORD=请改为长随机密码

# 默认提供商：deepseek / openai / gemini / dashscope / mimo
LLM_PROVIDER=deepseek
# DeepSeek 官方：deepseek-v4-pro（chat/reasoner 将于 2026-07-24 弃用，会自动映射）
# MiMo 须用小写：mimo-v2.5-pro（勿写 MiMo-V2.5-Pro）
LLM_MODEL=

DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DASHSCOPE_API_KEY=

# 智谱 AI 官方 https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=

# 小米 MiMo（OpenAI 兼容）https://token-plan-cn.xiaomimimo.com/v1
MIMO_API_KEY=
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# API 超时（秒）：连接 / 读取
API_CONNECT_TIMEOUT_SECONDS=30
API_READ_TIMEOUT_SECONDS=300
# 流式：首字超时（秒），防止一直停在 Calling API
STREAM_FIRST_CHUNK_TIMEOUT_SECONDS=90
# 流式：两次输出之间无新内容的超时（秒）
STREAM_IDLE_TIMEOUT_SECONDS=120
# 流式：每收到多少字刷新一次界面（越小越灵敏，略增卡顿）
STREAM_UI_UPDATE_CHARS=40
