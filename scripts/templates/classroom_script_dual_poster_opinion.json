{
  "schema_version": "1.0",
  "lesson": {
    "duration": "70min",
    "template_id": "dual_poster_opinion",
    "title": "高考英语应用文 · 观点理由类",
    "task_tag": "选海报 · 写理由"
  },
  "sequence": [
    {
      "id": "s01",
      "archetype": "cover_meta",
      "bind": {
        "static": {
          "title": "$lesson.title",
          "task_tag": "$lesson.task_tag"
        }
      }
    },
    {
      "id": "s02",
      "archetype": "question_stem",
      "bind": { "source": "question.stem" }
    },
    {
      "id": "s03",
      "archetype": "visual_poster",
      "bind": { "source": "question.visuals" },
      "options": { "one_per_slide": true },
      "skip_if_empty": true
    },
    {
      "id": "s03a",
      "archetype": "self_check_five",
      "bind": { "source": "stage1.self_check_five" }
    },
    {
      "id": "s04",
      "archetype": "thinking_core",
      "bind": { "source": "stage1.thinking_core" }
    },
    {
      "id": "s05",
      "archetype": "pitfall_contrast",
      "bind": { "source": "stage1.mistakes" }
    },
    {
      "id": "s06",
      "archetype": "peel_skeleton",
      "bind": { "source": "stage2.peel" }
    },
    {
      "id": "s07",
      "archetype": "essay_display",
      "bind": { "source": "stage2.essay_basic" },
      "options": { "title": "基础版范文", "badge": "基础版" },
      "skip_if_empty": true
    },
    {
      "id": "s08",
      "archetype": "essay_display",
      "bind": { "source": "stage2.essay_advanced_a" },
      "options": { "title": "高分版 A", "badge": "高分版 A" }
    },
    {
      "id": "s09",
      "archetype": "phrase_table"
    },
    {
      "id": "s10",
      "archetype": "phrase_footer"
    },
    {
      "id": "s11",
      "archetype": "vocab_table"
    },
    {
      "id": "s12",
      "archetype": "practice_migration",
      "bind": { "source": "stage4.migration" }
    },
    {
      "id": "s13",
      "archetype": "summary_formula",
      "bind": {
        "static": {
          "bullets": [
            "本课高分公式：观点 + 细节 + 分析 + 升华",
            "Stage1 思维 → Stage2 范文 → Stage3 语言 → Stage4 迁移"
          ]
        }
      }
    },
    {
      "id": "s14",
      "archetype": "summary_homework",
      "bind": { "source": "stage4.homework" }
    }
  ]
}
