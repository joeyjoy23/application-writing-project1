# 复制到 Streamlit Cloud → Settings → Secrets（勿提交含真实 Key 的文件到 Git）
#
# 若你只在网页侧边栏填 API Key，下面 LLM_* 可省略；
# 切勿写 LLM_MODEL = "MiMo-V2.5-Pro"（会 400），必须是小写 mimo-v2.5-pro。

# LLM_PROVIDER = "mimo"
# LLM_MODEL = "mimo-v2.5-pro"

# 可选：把 Key 放 Secrets，也可只在侧边栏输入
# MIMO_API_KEY = "tp-你的TokenPlan密钥"
# MIMO_BASE_URL = "https://token-plan-cn.xiaomimimo.com/v1"

# 管理员历史（可选）
# ADMIN_PASSWORD = "你的密码"

# Neon 云端历史（可选）
# DATABASE_URL = "postgresql://..."
